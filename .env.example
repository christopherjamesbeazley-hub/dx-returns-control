# Optional server-side external LLM bridge.
# Do not put real keys in Git. Configure these in Render or your local shell.

# OpenAI-compatible chat-completions endpoint. If using OPENAI_API_KEY, the server can default
# to https://api.openai.com/v1/chat/completions, but setting this explicitly is clearer.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# Render-style hosting can set HOST=0.0.0.0 and PORT from the platform.
HOST=127.0.0.1
PORT=5173
